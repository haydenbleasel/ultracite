      "destination": "/docs/configuration",
      "permanent": true
    },
    {
      "source": "/integration/husky",
      "destination": "/docs/git-hooks",
      "permanent": true
    },
    {
      "source": "/integration/lefthook",
      "destination": "/docs/git-hooks",
      "permanent": true
    }
  ]
}
