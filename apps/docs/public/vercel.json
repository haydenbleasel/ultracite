{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/sponsors", "destination": "/", "permanent": true },

    { "source": "/setup", "destination": "/docs/setup", "permanent": true },
    { "source": "/usage", "destination": "/docs/usage", "permanent": true },
    {
      "source": "/configuration",
      "destination": "/docs/configuration",
      "permanent": true
    },
    {
      "source": "/languages",
      "destination": "/docs/languages",
      "permanent": true
    },
    {
      "source": "/troubleshooting",
      "destination": "/docs/troubleshooting",
      "permanent": true
    },
    {
      "source": "/git-hooks",
      "destination": "/docs/git-hooks",
      "permanent": true
    },
    {
      "source": "/monorepos",
      "destination": "/docs/monorepos",
      "permanent": true
    },
    { "source": "/faq", "destination": "/docs/faq", "permanent": true },

    {
      "source": "/provider/:path*",
      "destination": "/docs/provider/:path*",
      "permanent": true
    },
    {
      "source": "/migrate/:path*",
      "destination": "/docs/migrate/:path*",
      "permanent": true
    },
    {
      "source": "/upgrade/:path*",
      "destination": "/docs/upgrade/:path*",
