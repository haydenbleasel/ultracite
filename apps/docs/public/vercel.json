    { "source": "/hooks", "destination": "/docs/ai/hooks", "permanent": true },
    {
      "source": "/docs/rules",
      "destination": "/docs/ai/rules",
      "permanent": true
    },
    {
      "source": "/docs/skills",
      "destination": "/docs/ai/skills",
      "permanent": true
    },
    {
      "source": "/docs/hooks",
      "destination": "/docs/ai/hooks",
      "permanent": true
    },

    { "source": "/mcp", "destination": "/", "permanent": true },
    { "source": "/mcp-server", "destination": "/", "permanent": true },
    { "source": "/docs/mcp-server", "destination": "/", "permanent": true },

    { "source": "/introduction", "destination": "/docs", "permanent": true },
    { "source": "/examples", "destination": "/docs/usage", "permanent": true },
