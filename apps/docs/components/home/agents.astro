---
import { agents } from "../../lib/agents";
import { agentLogos } from "../../lib/logos";

const featuredAgentIds = [
  "claude",
  "codex",
  "gemini",
  "warp",
  "opencode",
  "qwen",
  "copilot",
];

const featuredAgents = featuredAgentIds.flatMap((id) => {
  const agent = agents.find((a) => a.id === id);
  return agent ? [agent] : [];
});

const remainingCount = agents.length - featuredAgents.length;
---

<div class="grid gap-8">
  <div class="mx-auto grid max-w-3xl gap-4 text-center">
    <h2
      class="text-balance font-semibold text-2xl tracking-tighter sm:text-3xl md:text-4xl"
    >
      Works with all your favourite agents...
    </h2>
    <p class="text-balance text-muted-foreground tracking-tight sm:text-lg">
      Ultracite can generate rules files for all these popular IDEs and agents,
      so you can get the most of out of your AI integrations.
    </p>
  </div>
  <div class="mx-auto flex items-center justify-center -space-x-1">
    {
      featuredAgents.map((agent, index) => (
        <span class="hp-tt inline-flex" tabindex="0">
          <img
            alt={agent.name}
            class:list={[
              "size-10 overflow-hidden rounded-full ring-2 ring-background transition-transform will-change-transform hover:-translate-y-2 sm:size-14",
              index % 2 === 0 ? "hover:rotate-3" : "hover:-rotate-3",
            ]}
            src={agentLogos[agent.id]}
          />
          <span data-tt>{agent.name}</span>
        </span>
      ))
    }
    <span class="hp-tt inline-flex" tabindex="0">
      <span
        class="flex size-10 items-center justify-center overflow-hidden rounded-full border bg-secondary ring-2 ring-background transition-transform will-change-transform hover:-translate-y-2 hover:-rotate-3 sm:size-14"
      >
        <span class="text-muted-foreground text-xs sm:text-sm">
          + {remainingCount}
        </span>
      </span>
      <span data-tt>+ {remainingCount} more agents</span>
    </span>
  </div>
</div>
