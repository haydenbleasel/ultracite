---
import Icon from "./icon.astro";
import Logo from "./logo.astro";

const generalLinks = [
  { href: "/", label: "Home" },
  { href: "/docs", label: "Docs" },
];
---

<footer class="mt-24 mb-12 flex flex-col gap-12">
  <div class="flex flex-col gap-2">
    <p class="font-medium text-muted-foreground text-sm">General</p>
    {
      generalLinks.map((link) => (
        <a
          class="text-sm transition-colors hover:text-primary"
          href={link.href}
        >
          {link.label}
        </a>
      ))
    }
  </div>

  <div class="flex flex-col gap-6 border-t pt-8">
    <div
      class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center"
    >
      <div class="flex items-center gap-3">
        <Logo class="size-5" />
        <span class="font-semibold text-lg tracking-tight">Ultracite</span>
      </div>
      <div class="flex items-center gap-4">
        <a
          aria-label="Follow on X"
          class="text-muted-foreground transition-colors hover:text-primary"
          href="https://x.com/haydenbleasel"
          rel="noreferrer"
          target="_blank"
        >
          <Icon class="size-4" name="x" />
        </a>
        <a
          aria-label="View on GitHub"
          class="text-muted-foreground transition-colors hover:text-primary"
          href="https://github.com/haydenbleasel/ultracite"
          rel="noreferrer"
          target="_blank"
        >
          <Icon class="size-4" name="github" />
        </a>
      </div>
    </div>
    <div
      class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center"
    >
      <p class="text-muted-foreground text-sm">
        Free and open source, forever. Made by{" "}
        <a
          class="text-primary underline"
          href="https://x.com/haydenbleasel"
          rel="noreferrer"
          target="_blank">@haydenbleasel</a
        >
      </p>
    </div>
  </div>
</footer>
