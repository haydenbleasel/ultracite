{
  "name": "ultracite-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "The AI-ready formatter that helps you write and generate code faster.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "check-types": "turbo check-types",
    "check": "bun ./packages/cli/src/index.ts check",
    "fix": "bun ./packages/cli/src/index.ts fix",
    "validate:configs": "bun ./scripts/validate-configs.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build && changeset publish",
    "bump-deps": "npx npm-check-updates --deep -u && bun install",
    "bump-ui": "cd apps/docs && npx shadcn@latest add --all --overwrite && npx shadcn@latest migrate radix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.12",
    "@types/node": "catalog:",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5",
  "catalog": {
    "@biomejs/biome": "2.4.0",
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^1.6.1",
    "deepmerge": "^4.3.1",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.2"
  }
}
