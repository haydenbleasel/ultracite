{
  "name": "ultracite-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "The AI-ready formatter that helps you write and generate code faster.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "types": "turbo types",
    "check": "bun ./packages/cli/src/index.ts check",
    "fix": "bun ./packages/cli/src/index.ts fix",
    "validate:configs": "bun ./scripts/validate-configs.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build && changeset publish",
    "bump-deps": "npx npm-check-updates --deep -u && bun install",
    "bump-ui": "cd apps/docs && npx shadcn@latest add --all --overwrite && npx shadcn@latest migrate radix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260525.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "mitata": "^1.0.34",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14"
}
