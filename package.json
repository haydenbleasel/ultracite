{
  "name": "ultracite-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "The AI-ready formatter that helps you write and generate code faster.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "types": "turbo types",
    "check": "bun ./packages/cli/src/index.ts check",
    "fix": "bun ./packages/cli/src/index.ts fix",
    "validate:configs": "bun ./scripts/validate-configs.ts",
    "benchmark": "bun ./benchmark/index.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build && changeset publish",
    "bump-deps": "npx npm-check-updates --deep -u -x \"oxfmt, oxlint, @biomejs/biome, *eslint*, *prettier*, *stylelint*\" && bun install",
    "bump-tools": "npx npm-check-updates --deep -u --filter \"oxfmt, oxlint, @biomejs/biome, *eslint*, *prettier*, *stylelint*\" && bun install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260607.1",
    "concurrently": "^10.0.3",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "husky": "^9.1.7",
    "mitata": "^1.0.34",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-plugin-react-doctor": "^0.7.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@typescript-eslint/utils": "^8.62.1"
  },
  "packageManager": "bun@1.3.14",
  "patchedDependencies": {
    "oxfmt@0.58.0": "patches/oxfmt@0.58.0.patch"
  }
}
